{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/widgets",
      "destination": "/api/widgets"
    }
  ],
  "headers": [
    {
      "source": "/api/widgets",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
